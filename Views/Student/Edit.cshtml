@model Barral_ELNET1_MVC.Models.Student

@{
    ViewData["Title"] = "Edit Student";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="Index" class="text-muted text-decoration-none">
                    <i class="bi bi-arrow-left"></i> Back to Students
                </a>
            </li>
            <li class="breadcrumb-item active text-dark fw-medium" aria-current="page">Edit Student</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card flat-card">
                <div class="card-header flat-header">
                    <h4 class="mb-1 text-dark fw-bold">Edit Student</h4>
                    <p class="mb-0 text-muted small">Update information for <strong>@Model.Name</strong></p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="alert alert-flat-info mb-4" role="alert">
                        <span class="text-uppercase small fw-bold me-2">Student ID:</span>
                        <span class="font-monospace">@Model.Id</span>
                    </div>

                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-flat-danger" role="alert"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label text-dark fw-semibold small text-uppercase">
                                Student Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name" class="form-control flat-input" placeholder="Enter full name" />
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Course" class="form-label text-dark fw-semibold small text-uppercase">
                                Course <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Course" class="form-select flat-input">
                                <option value="">Select a course...</option>
                                <option value="BS Information Technology">BS Information Technology</option>
                                <option value="BS Computer Science">BS Computer Science</option>
                                <option value="BS Information Systems">BS Information Systems</option>
                                <option value="BS Engineering">BS Engineering</option>
                                <option value="BS Business Administration">BS Business Administration</option>
                            </select>
                            <span asp-validation-for="Course" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-5">
                            <label asp-for="Age" class="form-label text-dark fw-semibold small text-uppercase">
                                Age <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Age" type="number" min="1" max="100" class="form-control flat-input" placeholder="Enter age" />
                            <span asp-validation-for="Age" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex gap-3 pt-3 border-top border-muted">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-minimal px-4">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-dark btn-minimal px-4 ms-auto">
                                Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --color-dark: #494949;
        --color-muted: #8b8b8b;
        --color-border: #ECE8D9;
        --color-bg-light: #FAF6E9;
        --color-surface: #FFFDF6;
    }

    .breadcrumb {
        background: transparent;
        padding: 0;
    }

    .flat-card {
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-surface);
        box-shadow: none;
    }

    .flat-header {
        background: var(--color-bg-light);
        border-bottom: 1px solid var(--color-border);
        padding: 1.5rem 2rem;
        border-radius: 8px 8px 0 0 !important;
    }

    .flat-input {
        border: 1px solid var(--color-border);
        border-radius: 4px;
        padding: 0.75rem 1rem;
        background-color: var(--color-surface);
        color: var(--color-dark);
        transition: all 0.2s ease;
        box-shadow: none !important;
    }

        .flat-input:focus {
            border-color: var(--color-dark);
            background-color: #ffffff;
        }

    .btn-minimal {
        border-radius: 4px;
        font-weight: 500;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        font-size: 0.85rem;
        padding: 0.75rem 1.5rem;
        box-shadow: none !important;
    }

    .btn-dark {
        background-color: var(--color-dark);
        border-color: var(--color-dark);
        color: var(--color-surface);
    }

        .btn-dark:hover {
            background-color: #333333;
            color: #ffffff;
        }

    .btn-outline-secondary {
        border-color: var(--color-border);
        color: var(--color-dark);
    }

        .btn-outline-secondary:hover {
            background-color: var(--color-border);
            color: var(--color-dark);
        }

    .border-muted {
        border-color: var(--color-border) !important;
    }

    .alert-flat-info {
        background-color: var(--color-bg-light);
        border: 1px solid var(--color-border);
        color: var(--color-dark);
        border-radius: 4px;
        padding: 1rem;
    }

    .alert-flat-danger {
        background-color: #FFFDF6;
        border: 1px solid #e5a4a4;
        color: #d14949;
        border-radius: 4px;
    }
</style>
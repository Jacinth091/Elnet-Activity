@model Barral_ELNET1_MVC.Models.Student
@{
    ViewData["Title"] = "Edit Student";
    var courses = ViewBag.CourseOptionsList as List<string> ?? new List<string>();
}

<div class="page-header">
    <h1 class="page-title mb-1">Edit Student Record</h1>
    <p class="text-muted mb-0">Update the information for @Model.Name.</p>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="card p-4">
            <h5 class="fw-bold text-navy mb-4"><i class="bi bi-pencil-square me-2"></i> Update Information</h5>
            
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold small text-navy">Full Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger x-small"></span>
                </div>

                <div class="row mb-3">
                    <div class="col-md-8">
                        <label asp-for="Email" class="form-label fw-bold small text-navy">Email Address</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger x-small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Age" class="form-label fw-bold small text-navy">Age</label>
                        <input asp-for="Age" class="form-control" type="number" />
                        <span asp-validation-for="Age" class="text-danger x-small"></span>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Course" class="form-label fw-bold small text-navy">Program/Course</label>
                        <select asp-for="Course" class="form-select searchable-select">
                            <option value="">Select Course</option>
                            @foreach (var course in courses)
                            {
                                <option value="@course">@course</option>
                            }
                        </select>
                        <span asp-validation-for="Course" class="text-danger x-small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BirthDate" class="form-label fw-bold small text-navy">Birth Date</label>
                        <input asp-for="BirthDate" class="form-control" type="date" />
                        <span asp-validation-for="BirthDate" class="text-danger x-small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-teal px-4">Update Record</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.searchable-select').select2({
                placeholder: "Select Course",
                allowClear: true,
                width: '100%'
            });
        });
    </script>
    <style>
        .select2-container--default .select2-selection--single {
            border: 1px solid #B9B4C7;
            border-radius: 6px;
            height: 38px;
            padding: 5px;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 36px;
        }
    </style>
}

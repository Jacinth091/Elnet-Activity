@model Barral_ELNET1_MVC.Models.Student
@{
    ViewData["Title"] = "Add Student";
    var courses = ViewBag.CourseOptionsList as List<string> ?? new List<string>();
}
<div class="page-header mb-3">
    <h1 class="page-title mb-1">Add Student Record</h1>
    <p class="text-muted mb-0">Add a new student record.</p>
</div>

<div class="row justify-content-center">
    <div class="col-sm-12 col-md-8 col-lg-8">
        <div class="card p-4">
            <div class="card-header d-flex align-items-center mb-4">
                <div class="p-2 rounded-3 me-3" style="background-color: var(--color-tag-bg);">
                    <i class="bi bi-person-plus-fill fs-4 text-navy"></i>
                </div>
                <h3 class="h4 mb-0 fw-bold text-navy">Student Registration</h3>
            </div>
            
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="text-danger p-3 mb-4 w-100"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label small text-uppercase fw-bold text-secondary-muted">Full Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Juan Dela Cruz" />
                    <span asp-validation-for="Name" class="text-danger d-block small mt-1"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label small text-uppercase fw-bold text-secondary-muted">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="juan@university.edu.ph" />
                    <span asp-validation-for="Email" class="text-danger d-block small mt-1"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Course" class="form-label small text-uppercase fw-bold text-secondary-muted">Course / Department</label>
                    <select asp-for="Course" class="form-select searchable-select">
                        <option value="">Select Course...</option>
                        @foreach (var course in courses)
                        {
                            <option value="@course">@course</option>
                        }
                    </select>
                    <span asp-validation-for="Course" class="text-danger d-block small mt-1"></span>
                </div>
                <div class="row">
                    <div class="col-sm-12 col-md-6 mb-3">
                       <label asp-for="Age" class="form-label small text-uppercase fw-bold text-secondary-muted">Age (18-60)</label>
                        <input asp-for="Age" type="number" class="form-control" placeholder="18" />
                        <span asp-validation-for="Age" class="text-danger d-block small mt-1"></span>
                    </div>
                    <div class="col-sm-12 col-md-6 mb-3">
                        <label asp-for="BirthDate" class="form-label small text-uppercase fw-bold text-secondary-muted">Birth Date</label>
                        <input asp-for="BirthDate" class="form-control" type="date" />
                        <span asp-validation-for="BirthDate" class="text-danger d-block small mt-1"></span>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-top d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-success px-4 d-flex align-items-center">
                        <i class="bi bi-check2-circle me-2"></i> Save Record
                    </button>
                    <a asp-action="Index" class="btn btn-danger d-flex align-items-center">
                        <i class="bi bi-x-circle me-2"></i> Discard
                    </a>
                    <a asp-action="Index" class="btn btn-secondary ms-md-auto w-100 w-md-auto mt-2 mt-md-0">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.searchable-select').select2({
                placeholder: "Select Course...",
                allowClear: true,
                width: '100%'
            });
        });
    </script>
    <style>
        .select2-container--default .select2-selection--single {
            border: 1.5px solid var(--color-border-input) !important;
            border-radius: 6px !important;
            height: 44px !important;
            padding: 6px 14px !important;
            background-color: var(--color-surface) !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 42px !important;
            right: 10px !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 28px !important;
            color: var(--color-text-primary) !important;
            padding-left: 0 !important;
        }
    </style>
}

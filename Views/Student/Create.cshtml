@model Barral_ELNET1_MVC.Models.Student
@{
    ViewData["Title"] = "Register Student";
}

<div class="page-header">
    <h1 class="page-title mb-1">Register New Student</h1>
    <p class="text-muted mb-0">Complete the form below to add a new record to the directory.</p>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="card p-4">
            <h5 class="fw-bold text-navy mb-4"><i class="bi bi-person-badge me-2"></i> Personal Information</h5>
            
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold small text-navy">Full Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Firstname Lastname" />
                    <span asp-validation-for="Name" class="text-danger x-small"></span>
                </div>

                <div class="row mb-3">
                    <div class="col-md-8">
                        <label asp-for="Email" class="form-label fw-bold small text-navy">Email Address</label>
                        <input asp-for="Email" class="form-control" placeholder="name@example.edu" />
                        <span asp-validation-for="Email" class="text-danger x-small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Age" class="form-label fw-bold small text-navy">Age</label>
                        <input asp-for="Age" class="form-control" type="number" min="18" max="100" />
                        <span asp-validation-for="Age" class="text-danger x-small"></span>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Course" class="form-label fw-bold small text-navy">Program/Course</label>
                        <input asp-for="Course" class="form-control" placeholder="e.g., BSIT" />
                        <span asp-validation-for="Course" class="text-danger x-small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BirthDate" class="form-label fw-bold small text-navy">Birth Date</label>
                        <input asp-for="BirthDate" class="form-control" type="date" />
                        <span asp-validation-for="BirthDate" class="text-danger x-small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-teal px-4">Save Student Record</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Back to Directory</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

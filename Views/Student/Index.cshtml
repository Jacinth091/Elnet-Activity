@model IEnumerable<Barral_ELNET1_MVC.Models.Student>

@{
    ViewData["Title"] = "Student Directory";
    var searchTerm = ViewBag.SearchTerm as string;
    var courseFilter = ViewBag.CourseFilter as string;
    var courseOptions = ViewBag.CourseOptions as List<string> ?? new List<string>();
}

<!-- Page Header following the Dashboard/Admin pattern -->
<div class="page-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="page-title">Student Directory</h1>
        <p class="text-secondary-muted mb-0">
            <i class="bi bi-people me-2"></i>
            Registry of @Model.Count() @(Model.Count() == 1 ? "student" : "students") enrolled in the system.
        </p>
    </div>
    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary mt-3 mt-md-0">
            <i class="bi bi-plus-circle-fill me-2"></i>Add New Student
        </a>
    }
</div>

<!-- Search and Filter Toolbar sitting on Sand background -->
<div class="card mb-4 border-0 shadow-sm" style="background-color: rgba(255, 255, 255, 0.5);">
    <div class="card-body p-3">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-sm-12 col-md-5">
                <label class="form-label fw-bold small text-navy">Search Records</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="searchTerm" value="@searchTerm" class="form-control border-start-0" placeholder="Search by name, email, or ID..." />
                </div>
            </div>
            <div class="col-sm-12 col-md-4">
                <label class="form-label fw-bold small text-navy">Program / Course</label>
                <select name="courseFilter" class="form-select">
                    <option value="">All Programs</option>
                    @foreach (var course in courseOptions)
                    {
                        @if (course == courseFilter)
                        {
                            <option value="@course" selected>@course</option>
                        }
                        else
                        {
                            <option value="@course">@course</option>
                        }
                    }
                </select>
            </div>
            <div class="col-sm-12 col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-filter me-2"></i>Apply
                </button>
                <a asp-action="Index" class="btn btn-cancel" title="Reset Filters">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Main Content Card -->
<div class="card shadow-sm">
    <!-- Table Grid with scannability focus -->
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Full Name</th>
                    <th>Email Address</th>
                    <th>Course / Track</th>
                    <th>Age</th>
                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                    {
                        <th class="text-end pe-4">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 small fw-bold text-secondary-muted">
                            #@item.Id.ToString("D3")
                        </td>
                        <td class="fw-medium text-navy">@item.Name</td>
                        <td class="text-secondary-muted">@item.Email</td>
                        <td>
                            <span class="badge bg-secondary text-dark border-0" style="background-color: var(--color-tag-bg) !important; color: var(--color-tag-text) !important;">
                                @item.Course
                            </span>
                        </td>
                        <td>@item.Age</td>
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                        {
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary px-3">
                                        <i class="bi bi-pencil-square me-1"></i>Edit
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this student record?');" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger px-3">
                                            <i class="bi bi-trash3 me-1"></i>Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        }
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <i class="bi bi-database-exclamation fs-1 text-muted d-block mb-2"></i>
                            <p class="text-muted">No student records match your criteria.</p>
                            <a asp-action="Index" class="btn btn-sm btn-outline-primary">Clear all filters</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model List<Barral_ELNET1_MVC.Models.Student>

@{
    ViewData["Title"] = "Student List";
}

<div class="container mt-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="display-6 fw-bold mb-1 text-dark">Student Directory</h1>
            <p class="text-muted mb-0">
                <i class="bi bi-people"></i>
                <span class="ms-2">@Model.Count @(Model.Count == 1 ? "student" : "students") enrolled</span>
            </p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-dark btn-minimal">
                <i class="bi bi-plus-lg"></i> Add Student
            </a>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row g-4">
            @foreach (var student in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 flat-card">
                        <div class="card-header flat-header d-flex align-items-center">
                            <div class="student-avatar me-3">
                                @student.Name.Substring(0, 1).ToUpper()
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="card-title mb-0 fw-bold text-dark">@student.Name</h5>
                                <small class="text-muted">ID: @student.Id</small>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="mb-4">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-book text-muted me-2"></i>
                                    <span class="text-muted small text-uppercase fw-semibold me-2">Course:</span>
                                    <span class="text-dark fw-medium">@student.Course</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-calendar text-muted me-2"></i>
                                    <span class="text-muted small text-uppercase fw-semibold me-2">Age:</span>
                                    <span class="text-dark fw-medium">@student.Age years</span>
                                </div>
                            </div>

                            <div class="text-start mb-2">
                                @if (student.Age >= 18)
                                {
                                    <span class="badge badge-flat-dark">
                                        Adult
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-flat-light">
                                        Minor
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="card-footer flat-footer">
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-outline-dark btn-sm flex-grow-1 btn-minimal">
                                    Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@student.Id" method="post" class="flex-grow-1">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-secondary btn-sm w-100 btn-minimal"
                                            onclick="return confirm('Are you sure you want to delete @student.Name?');">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state text-center py-5">
            <i class="bi bi-inbox text-muted display-4 d-block mb-3"></i>
            <h4 class="text-dark fw-bold">No Students Yet</h4>
            <p class="text-muted mb-4">Get started by adding your first student to the system.</p>
            <a asp-action="Create" class="btn btn-dark btn-minimal px-4">
                Add First Student
            </a>
        </div>
    }
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    /* Warm Minimalist Palette */
    :root {
        --color-dark: #494949;
        --color-muted: #8b8b8b;
        --color-border: #ECE8D9;
        --color-bg-light: #FAF6E9;
        --color-surface: #FFFDF6;
    }

    .flat-card {
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-surface);
        transition: border-color 0.2s ease;
        box-shadow: none;
    }

        .flat-card:hover {
            border-color: var(--color-dark);
        }

    .flat-header {
        background: transparent;
        border-bottom: 1px solid var(--color-border);
        padding: 1.25rem;
    }

    .flat-footer {
        background: transparent;
        border-top: 1px solid var(--color-border);
        padding: 1.25rem;
    }

    .student-avatar {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 4px;
        background: var(--color-bg-light);
        border: 1px solid var(--color-border);
        color: var(--color-dark);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 1rem;
    }

    .badge-flat-dark {
        background-color: var(--color-dark);
        color: var(--color-surface);
        font-weight: 500;
        padding: 0.35rem 0.75rem;
        border-radius: 4px;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .badge-flat-light {
        background-color: var(--color-bg-light);
        color: var(--color-dark);
        border: 1px solid var(--color-border);
        font-weight: 500;
        padding: 0.35rem 0.75rem;
        border-radius: 4px;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .btn-minimal {
        border-radius: 4px;
        font-weight: 500;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        font-size: 0.8rem;
        padding: 0.6rem 1rem;
        box-shadow: none !important;
    }

    .btn-dark {
        background-color: var(--color-dark);
        border-color: var(--color-dark);
        color: var(--color-surface);
    }

        .btn-dark:hover {
            background-color: #333333;
            color: #ffffff;
        }

    .btn-outline-dark {
        border-color: var(--color-dark);
        color: var(--color-dark);
    }

        .btn-outline-dark:hover {
            background-color: var(--color-dark);
            color: var(--color-surface);
        }

    .btn-outline-secondary {
        border-color: var(--color-border);
        color: var(--color-dark);
    }

        .btn-outline-secondary:hover {
            background-color: var(--color-border);
            color: var(--color-dark);
        }

    .empty-state {
        border: 1px dashed var(--color-border);
        border-radius: 8px;
        background: var(--color-surface);
    }
</style>
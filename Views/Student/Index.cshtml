@model List<Barral_ELNET1_MVC.Models.Student>

@{
    ViewData["Title"] = "Student Directory";
}

<div class="page-header d-flex justify-content-between align-items-end">
    <div>
        <h1 class="page-title">Student Directory</h1>
        <p class="text-secondary-muted mb-0">
            <i class="bi bi-people-fill me-2"></i>
            Managing @Model.Count @(Model.Count == 1 ? "student" : "students") in the system
        </p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus-fill me-2"></i>Add Student
        </a>
    }
</div>

<!-- Search & Filter Section -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label small text-uppercase fw-bold text-secondary-muted">Search Records</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" 
                           class="form-control" placeholder="Name, Email, or ID..." />
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label small text-uppercase fw-bold text-secondary-muted">Filter by Course</label>
                <select name="courseFilter" class="form-select">
                    <option value="">All Departments</option>
                    @foreach (var course in (IEnumerable<string>)ViewBag.CourseOptions)
                    {
                        <!option value="@course" @(ViewBag.CourseFilter == course ? "selected" : "")>@course</!option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Apply</button>
                <a asp-action="Index" class="btn btn-secondary flex-grow-1">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Data Table -->
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Student Name</th>
                    <th>Course</th>
                    <th>Age</th>
                    <th>Email</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th class="text-end">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var student in Model)
                    {
                        <tr>
                            <td class="small fw-bold text-secondary-muted">#@student.Id.ToString("D3")</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar me-3">@student.Name[0]</div>
                                    <span class="fw-semibold">@student.Name</span>
                                </div>
                            </td>
                            <td><span class="badge bg-light text-navy border">@student.Course</span></td>
                            <td>@student.Age</td>
                            <td class="text-secondary-muted">@student.Email</td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-sm btn-secondary px-3">
                                            <i class="bi bi-pencil-square me-1"></i>Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@student.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger px-3" 
                                                    onclick="return confirm('Are you sure you want to delete this student record?');">
                                                <i class="bi bi-trash3 me-1"></i>Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="@(User.IsInRole("Admin") ? 6 : 5)" class="text-center py-5">
                            <i class="bi bi-clipboard2-x display-4 text-accent d-block mb-3"></i>
                            <p class="text-secondary-muted mb-0">No student records found matching your search.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


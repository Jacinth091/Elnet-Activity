@model IEnumerable<Barral_ELNET1_MVC.Models.User>

@{
    ViewData["Title"] = "Admin Directory";
    var currentAdminId = ViewBag.CurrentAdminId;
}

<div class="page-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="page-title">Admin Directory</h1>
        <p class="text-secondary-muted mb-0">
            <i class="bi bi-person-gear me-2"></i>
            Managing @Model.Count() @(Model.Count() == 1 ? "administrator" : "administrators")
        </p>
    </div>
    <a asp-action="Create" class="btn btn-primary mt-3 mt-md-0">
        <i class="bi bi-plus-circle-fill me-2"></i>Add New Admin
    </a>
</div>

<div class="card shadow-sm mt-4">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Age</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var admin in Model)
                {
                    <tr>
                        <td class="ps-4 small fw-bold text-secondary-muted">#@admin.Id.ToString("D3")</td>
                        <td class="fw-medium text-navy">@admin.Name</td>
                        <td class="text-secondary-muted">@admin.Email</td>
                        <td>@admin.Age</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@admin.Id" class="btn btn-sm btn-outline-primary px-3">
                                    <i class="bi bi-pencil-square me-1"></i>Edit
                                </a>
                                @if (admin.Id != (int)currentAdminId)
                                {
                                    <form asp-action="Delete" asp-route-id="@admin.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this admin account?');" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger px-3">
                                            <i class="bi bi-trash3 me-1"></i>Delete
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model Barral_ELNET1_MVC.Models.Transaction
@{
    ViewData["Title"] = "New Transaction";
}

<div class="page-header">
    <h1 class="page-title mb-1">New Transaction</h1>
    <p class="text-muted mb-0">Record a new payment or financial activity.</p>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="card p-4">
            <h5 class="fw-bold text-navy mb-4"><i class="bi bi-cash-stack me-2"></i> Transaction Details</h5>
            
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="StudentId" class="form-label fw-bold small text-navy">Select Student</label>
                    <select asp-for="StudentId" class="form-select" asp-items="ViewBag.Students">
                        <option value="">-- Choose a student --</option>
                    </select>
                    <span asp-validation-for="StudentId" class="text-danger x-small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold small text-navy">Description</label>
                    <input asp-for="Description" class="form-control" placeholder="e.g., Tuition Fee Payment" />
                    <span asp-validation-for="Description" class="text-danger x-small"></span>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Amount" class="form-label fw-bold small text-navy">Amount (₱)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">₱</span>
                            <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Amount" class="text-danger x-small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Date" class="form-label fw-bold small text-navy">Payment Date</label>
                        <input asp-for="Date" class="form-control" type="date" />
                        <span asp-validation-for="Date" class="text-danger x-small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-teal px-4">Record Transaction</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

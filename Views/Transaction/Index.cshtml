@model IEnumerable<Barral_ELNET1_MVC.Models.Transaction>
@{
    ViewData["Title"] = "Transaction Log";
    var isAdmin = User.IsInRole("Admin");
}

<div class="page-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="page-title">Transaction Log</h1>
        <p class="text-secondary-muted mb-0">
            <i class="bi bi-receipt-cutoff me-2"></i>
            Monitoring all financial activities and student payments.
        </p>
    </div>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-primary mt-3 mt-md-0">
            <i class="bi bi-plus-square-fill me-2"></i>New Transaction
        </a>
    }
</div>

<!-- Search & Filter Log sitting on Sand background -->
<div class="card mb-4 border-0 shadow-sm" style="background-color: rgba(255, 255, 255, 0.5);">
    <div class="card-body p-3">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-sm-12 col-md-5">
                <label class="form-label fw-bold small text-navy">Search Description</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="searchDesc" value="@ViewBag.SearchDesc" 
                           class="form-control border-start-0" placeholder="Search by description..." />
                </div>
            </div>
            <div class="col-sm-12 col-md-4">
                <label class="form-label fw-bold small text-navy">Filter by Date</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar3 text-muted"></i></span>
                    <input type="date" name="filterDate" value="@ViewBag.FilterDate" class="form-control border-start-0" />
                </div>
            </div>
            <div class="col-sm-12 col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Filter</button>
                <a asp-action="Index" class="btn btn-cancel px-3" title="Reset Filters"><i class="bi bi-arrow-counterclockwise"></i></a>
            </div>
        </form>
    </div>
</div>

<!-- Transaction Table -->
<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Date</th>
                    <th>Student Details</th>
                    <th>Description</th>
                    <th class="text-end pe-4">Amount</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-secondary-muted small">@item.Date.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="fw-semibold text-navy">@(item.Student?.Name ?? "Guest Student")</div>
                                <div class="x-small text-accent text-uppercase">@(item.Student?.Course ?? "General")</div>
                            </td>
                            <td class="text-secondary-muted">@item.Description</td>
                            <td class="text-end pe-4 fw-bold text-navy">
                                ₱@item.Amount.ToString("N2")
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <i class="bi bi-inbox-fill display-4 text-accent d-block mb-3"></i>
                            <p class="text-secondary-muted mb-0">No transaction logs match your filter criteria.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

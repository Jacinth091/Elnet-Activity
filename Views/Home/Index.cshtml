@{
    ViewData["Title"] = "Home Page";
}

<div class="landing-hero text-center py-5 mb-5">
    <div class="container py-lg-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="hero-icon-container mb-4">
                    <i class="bi bi-journal-bookmark"></i>
                </div>
                <h1 class="display-5 fw-bold mb-3 tracking-tight text-navy">Welcome to StudentHub</h1>
                <p class="lead mb-5 px-lg-5 text-secondary-muted">
                    A specialized administrative platform designed for precision, 
                    minimalist efficiency, and secure data management.
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Student" asp-action="Index" class="btn btn-primary px-5 py-3">
                        <i class="bi bi-list-ul me-2"></i> View Directory
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary px-5 py-3">
                        <i class="bi bi-lock-fill me-2"></i> Admin Portal
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="feature-card h-100 p-5">
                <i class="bi bi-people fs-1 mb-4 d-block text-secondary-muted"></i>
                <h5 class="fw-bold mb-3 text-navy">Data Integrity</h5>
                <p class="small mb-0 text-secondary-muted">
                    Maintain accurate student records with strict validation and role-based access control.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card h-100 p-5">
                <i class="bi bi-receipt-cutoff fs-1 mb-4 d-block text-secondary-muted"></i>
                <h5 class="fw-bold mb-3 text-navy">Financial Tracking</h5>
                <p class="small mb-0 text-secondary-muted">
                    Seamlessly record and audit student transactions within our centralized ledger.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card h-100 p-5">
                <i class="bi bi-shield-check fs-1 mb-4 d-block text-secondary-muted"></i>
                <h5 class="fw-bold mb-3 text-navy">Enterprise Security</h5>
                <p class="small mb-0 text-secondary-muted">
                    Built with modern security standards to protect sensitive institutional information.
                </p>
            </div>
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Home Page";
}

<div class="landing-hero text-center">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="hero-icon mb-4">
                    <i class="bi bi-journal-bookmark text-dark"></i>
                </div>
                <h1 class="display-5 fw-bold text-dark mb-3">Welcome to the Student System</h1>
                <p class="lead text-muted mb-4">
                    A minimal, efficient, and flat-design platform to manage your student directory,
                    track courses, and organize records seamlessly.
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Student" asp-action="Index" class="btn btn-dark btn-minimal px-4 py-2">
                        View Directory
                    </a>
                    <a asp-controller="Student" asp-action="Create" class="btn btn-outline-secondary btn-minimal px-4 py-2">
                        Add Student
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="feature-card h-100 p-4">
                <i class="bi bi-people display-6 text-dark mb-3 d-block"></i>
                <h5 class="fw-bold text-dark mb-2">Manage Records</h5>
                <p class="text-muted small mb-0">
                    Keep track of all student information in one centralized, secure location without unnecessary clutter.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card h-100 p-4">
                <i class="bi bi-pencil-square display-6 text-dark mb-3 d-block"></i>
                <h5 class="fw-bold text-dark mb-2">Quick Edits</h5>
                <p class="text-muted small mb-0">
                    Update course assignments, adjust ages, and modify details instantly with a flat, distraction-free interface.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card h-100 p-4">
                <i class="bi bi-shield-check display-6 text-dark mb-3 d-block"></i>
                <h5 class="fw-bold text-dark mb-2">Safe & Secure</h5>
                <p class="text-muted small mb-0">
                    Built on ASP.NET Core with built-in protections like anti-forgery tokens for safe data handling.
                </p>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .landing-hero {
        background-color: var(--color-bg-light, #FAF6E9);
        border-bottom: 1px solid var(--color-border, #ECE8D9);
        padding-top: 2rem;
        padding-bottom: 2rem;
    }

    .hero-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 5rem;
        height: 5rem;
        background-color: var(--color-surface, #FFFDF6);
        border: 1px solid var(--color-border, #ECE8D9);
        border-radius: 8px;
        font-size: 2.5rem;
    }

    .feature-card {
        background-color: var(--color-surface, #FFFDF6);
        border: 1px solid var(--color-border, #ECE8D9);
        border-radius: 8px;
        transition: border-color 0.2s ease;
    }

        .feature-card:hover {
            border-color: var(--color-dark, #494949);
        }

    .btn-minimal {
        border-radius: 4px;
        font-weight: 500;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        font-size: 0.85rem;
        box-shadow: none !important;
    }

    .btn-dark {
        background-color: #494949;
        border-color: #494949;
        color: #FFFDF6;
    }

        .btn-dark:hover {
            background-color: #333333;
            color: #ffffff;
        }

    .btn-outline-secondary {
        border-color: #ECE8D9;
        color: #494949;
    }

        .btn-outline-secondary:hover {
            background-color: #ECE8D9;
            color: #494949;
        }
</style>
@{
    ViewData["Title"] = "Home Page";
}

<div class="landing-hero p-5 mb-5 text-center">
    <div class="hero-icon-container mb-4">
        <i class="bi bi-mortarboard-fill"></i>
    </div>
    <h1 class="display-5 fw-bold text-navy mb-3 tracking-tight">Modern Student Management</h1>
    <p class="lead text-secondary-muted mb-4 mx-auto" style="max-width: 600px;">
        A streamlined, role-based platform for managing student records and tracking financial transactions with absolute precision.
    </p>
    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Student" asp-action="Index" class="btn btn-primary px-4 py-2">
            Explore Directory
        </a>
        @if (User.Identity?.IsAuthenticated != true)
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary px-4 py-2">
                Admin Access
            </a>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="feature-card p-4 h-100">
            <div class="header-icon-box mb-3" style="width: 3.5rem; height: 3.5rem; font-size: 1.5rem; background-color: var(--color-tag-bg); color: var(--color-text-primary);">
                <i class="bi bi-shield-lock"></i>
            </div>
            <h5 class="fw-bold text-navy mb-2">Role-Based Access</h5>
            <p class="text-secondary-muted small mb-0">
                Securely manage permissions with distinct Admin and Guest roles, ensuring data integrity across the platform.
            </p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card p-4 h-100">
            <div class="header-icon-box mb-3" style="width: 3.5rem; height: 3.5rem; font-size: 1.5rem; background-color: var(--color-tag-bg); color: var(--color-text-primary);">
                <i class="bi bi-search"></i>
            </div>
            <h5 class="fw-bold text-navy mb-2">Advanced Filtering</h5>
            <p class="text-secondary-muted small mb-0">
                Quickly locate records with real-time search and multi-criteria filtering by date, category, and department.
            </p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card p-4 h-100">
            <div class="header-icon-box mb-3" style="width: 3.5rem; height: 3.5rem; font-size: 1.5rem; background-color: var(--color-tag-bg); color: var(--color-text-primary);">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <h5 class="fw-bold text-navy mb-2">Dynamic Insights</h5>
            <p class="text-secondary-muted small mb-0">
                Visualize financial trends and system metrics with an interactive dashboard powered by real-time data.
            </p>
        </div>
    </div>
</div>

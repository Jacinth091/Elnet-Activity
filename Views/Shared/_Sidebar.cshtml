<nav id="sidebar" class="portal-sidebar flex-shrink-0">
    <div class="sidebar-inner h-100 d-flex flex-column">
        
        <div class="sidebar-header d-flex align-items-center justify-content-between px-4 py-4">
            <div class="brand-box d-flex align-items-center label-visible">
                <i class="bi bi-mortarboard-fill fs-3 text-accent"></i>
                <span class="ms-3 fs-5 fw-bold text-white tracking-tight">StudentHub</span>
            </div>
            <!-- Toggle only visible when expanded -->
            <i id="sidebarClose" class="bi bi-chevron-left fs-4 text-accent label-visible" style="cursor: pointer; margin-left: auto;" title="Collapse Sidebar"></i>
            <!-- Minimal Icon for collapsed state (no button functionality, just branding) -->
            <div class="collapsed-brand d-none">
                 <i class="bi bi-mortarboard-fill fs-3 text-accent"></i>
            </div>
        </div>

        <div class="sidebar-content px-2 mt-2">
            <ul class="nav flex-column gap-2">
                <li class="nav-item">
                    <a asp-controller="Dashboard" asp-action="Index"
                       class="nav-link-portal d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                       title="Dashboard">
                        <i class="bi bi-grid-1x2-fill icon"></i>
                        <span class="label-visible ms-3">Admin Dashboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Student" asp-action="Index"
                       class="nav-link-portal d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "Student" ? "active" : "")"
                       title="Directory">
                        <i class="bi bi-people-fill icon"></i>
                        <span class="label-visible ms-3">Student Directory</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Transaction" asp-action="Index"
                       class="nav-link-portal d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "Transaction" ? "active" : "")"
                       title="Transactions">
                        <i class="bi bi-receipt-cutoff icon"></i>
                        <span class="label-visible ms-3">Transaction Log</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Admin" asp-action="Create"
                       class="nav-link-portal d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
                       title="Manage Admins">
                        <i class="bi bi-shield-lock-fill icon"></i>
                        <span class="label-visible ms-3">Manage Admins</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="sidebar-footer mt-auto p-3">
            <div class="user-card d-flex align-items-center p-3 rounded mb-3 label-visible">
                <div class="user-avatar">
                    @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "A")
                </div>
                <div class="ms-3 overflow-hidden">
                    <p class="mb-0 fw-bold text-white text-truncate small">@(User.Identity?.Name ?? "Admin")</p>
                    <p class="mb-0 x-small text-accent opacity-75 fw-bold">ADMINISTRATOR</p>
                </div>
            </div>

            <form asp-controller="Account" asp-action="Logout" method="post" class="w-100">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-logout w-100 d-flex align-items-center justify-content-center py-2" title="Sign Out">
                    <i class="bi bi-box-arrow-left me-2"></i>
                    <span class="label-visible">Sign Out</span>
                </button>
            </form>
        </div>
    </div>
</nav>
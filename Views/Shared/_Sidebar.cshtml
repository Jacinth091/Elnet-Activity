@using System.Security.Claims
<nav id="sidebar" class="portal-sidebar d-flex flex-column flex-shrink-0 collapsed sidebar-init">
    <script>
        (function() {
            const isExpanded = localStorage.getItem('sidebar-expanded') === 'true';
            const sidebar = document.currentScript.parentElement;
            if (isExpanded) {
                sidebar.classList.remove('collapsed');
            } else {
                sidebar.classList.add('collapsed');
            }
        })();
    </script>
    
    <!-- Header -->
    <div class="sidebar-header d-flex align-items-center mb-4 px-3 mt-3" style="cursor: pointer;">
        <div class="d-flex align-items-center justify-content-center bg-white" style="width: 32px; height: 32px; border-radius: 6px;">
            <i class="bi bi-mortarboard-fill fs-5" style="color: var(--color-primary);"></i>
        </div>
        <span class="fs-6 fw-bold text-white ms-3 label-visible">StudentHub</span>
    </div>

    <!-- Navigation -->
    <ul class="nav flex-column mb-auto px-2">
        <li class="nav-item">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Dashboard" asp-action="Index" 
                   class="nav-link-portal @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                   title="Dashboard">
                    <i class="bi bi-speedometer2 icon"></i>
                    <span class="ms-3 label-visible">Dashboard</span>
                </a>
            }
            else
            {
                <a asp-controller="Dashboard" asp-action="Guest" 
                   class="nav-link-portal @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "Guest" ? "active" : "")"
                   title="Dashboard">
                    <i class="bi bi-speedometer2 icon"></i>
                    <span class="ms-3 label-visible">Dashboard</span>
                </a>
            }
        </li>
        <li class="nav-item">
            <a asp-controller="Student" asp-action="Index" 
               class="nav-link-portal @(ViewContext.RouteData.Values["controller"]?.ToString() == "Student" ? "active" : "")"
               title="Students">
                <i class="bi bi-people icon"></i>
                <span class="ms-3 label-visible">Students</span>
            </a>
        </li>
        <li class="nav-item">
            <a asp-controller="Transaction" asp-action="Index" 
               class="nav-link-portal @(ViewContext.RouteData.Values["controller"]?.ToString() == "Transaction" ? "active" : "")"
               title="Transactions">
                <i class="bi bi-receipt icon"></i>
                <span class="ms-3 label-visible">Transactions</span>
            </a>
        </li>
        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a asp-controller="Admin" asp-action="Index" 
                   class="nav-link-portal @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                   title="Manage Admins">
                    <i class="bi bi-person-gear icon"></i>
                    <span class="ms-3 label-visible">Manage Admins</span>
                </a>
            </li>
            <li class="nav-item">
                <a asp-controller="Admin" asp-action="Guests" 
                   class="nav-link-portal @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Guests" ? "active" : "")"
                   title="Manage Guests">
                    <i class="bi bi-people icon"></i>
                    <span class="ms-3 label-visible">Manage Guests</span>
                </a>
            </li>
        }
    </ul>

    <!-- Footer -->
    <div class="mt-auto pt-3 border-top border-white border-opacity-10 px-2">
        <div class="p-2 rounded mb-3 d-flex align-items-center" style="background-color: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);">
            <div class="user-avatar text-uppercase text-white" style="width: 32px; height: 32px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; font-weight: 600; background-color: var(--color-primary);">
                @(User.Identity?.Name?[0] ?? 'U')
            </div>
            <div class="ms-2 label-visible overflow-hidden">
                <p class="mb-0 text-white small fw-bold text-truncate">@User.Identity?.Name</p>
                <p class="mb-0 text-muted" style="font-size: 11px;">@(User.IsInRole("Admin") ? "Admin Account" : "Guest Account")</p>
            </div>
        </div>
        
        <form asp-controller="Account" asp-action="Logout" method="post" class="mb-3">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-logout w-100 d-flex align-items-center justify-content-center py-2 text-white border-white border-opacity-25" style="font-size: 0.8125rem;" title="Logout">
                <i class="bi bi-box-arrow-left"></i>
                <span class="ms-2 label-visible">Logout</span>
            </button>
        </form>
    </div>
</nav>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Information System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --color-dark: #494949;
            --color-muted: #8b8b8b;
            --color-border: #ECE8D9;
            --color-bg-light: #FAF6E9;
            --color-surface: #FFFDF6;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background-color: var(--color-bg-light);
            color: var(--color-dark);
            line-height: 1.6;
        }

        .navbar {
            background: var(--color-surface) !important;
            border-bottom: 1px solid var(--color-border);
            padding: 0.75rem 0;
        }

        .navbar-brand {
            font-weight: 600;
            font-size: 1.125rem;
            color: var(--color-dark) !important;
            letter-spacing: 0.025em;
        }

        .nav-link {
            color: var(--color-muted) !important;
            font-weight: 500;
            padding: 0.5rem 1rem !important;
            transition: color 0.2s ease;
        }

            .nav-link:hover {
                color: var(--color-dark) !important;
            }

        .container {
            max-width: 1000px;
        }

        main {
            min-height: calc(100vh - 300px);
            padding: 0 0 3rem 0;
        }

        .flat-footer {
            background-color: var(--color-bg-light);
            border-top: 1px solid var(--color-border);
            margin-top: 4rem;
        }

        .footer-link {
            color: var(--color-muted);
            text-decoration: none;
            font-size: 0.875rem;
            transition: color 0.2s ease;
        }

            .footer-link:hover {
                color: var(--color-dark);
            }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Student Management System
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Student" asp-action="Index">Students</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <partial name="_Header" />
    </header>

    <div class="container flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="flat-footer py-4 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
                    <span class="text-dark fw-bold me-2">Student System</span>
                    <span class="text-muted small">&copy; 2026. All rights reserved.</span>
                </div>

                <div class="col-md-4 text-center mb-3 mb-md-0">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="footer-link mx-2">Home</a>
                    <a asp-area="" asp-controller="Student" asp-action="Index" class="footer-link mx-2">Directory</a>
                </div>

                <div class="col-md-4 text-center text-md-end">
                    <a href="#" class="footer-link text-uppercase small fw-semibold">
                        <i class="bi bi-arrow-up me-1"></i> Back to top
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@using System.Text.Json
@model Barral_ELNET1_MVC.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Admin Dashboard</h1>
        <p class="text-secondary-muted mb-0">System overview and financial activity summary.</p>
    </div>
    <div class="text-end">
        <span class="badge bg-light text-navy border px-3 py-2">
            <i class="bi bi-clock-history me-2"></i>Last sync: @Model.LastUpdated.ToString("hh:mm tt")
        </span>
    </div>
</div>

<!-- KPI Summary Cards -->
<div class="row g-4 mb-5">
    <div class="col-sm-12 col-md-4">
        <div class="card h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="header-icon-box shadow-sm" style="width: 3rem; height: 3rem; font-size: 1.25rem;">
                        <i class="bi bi-receipt-cutoff"></i>
                    </div>
                    <span class="small fw-bold text-uppercase text-secondary-muted">Transactions</span>
                </div>
                <h2 class="display-6 fw-bold mb-0 text-navy">@Model.TotalTransactions</h2>
                <p class="small mb-0 mt-2 text-secondary-muted fw-medium">Lifetime record count</p>
            </div>
        </div>
    </div>
    <div class="col-sm-12 col-md-4">
        <div class="card h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="header-icon-box shadow-sm" style="width: 3rem; height: 3rem; font-size: 1.25rem;">
                        <i class="bi bi-wallet2"></i>
                    </div>
                    <span class="small fw-bold text-uppercase text-secondary-muted">Total Revenue</span>
                </div>
                <h2 class="display-6 fw-bold mb-0 text-navy">₱@Model.TotalAmount.ToString("N0")</h2>
                <p class="small mb-0 mt-2 text-secondary-muted fw-medium">Consolidated payments</p>
            </div>
        </div>
    </div>
    <div class="col-sm-12 col-md-4">
        <div class="card h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="header-icon-box shadow-sm" style="width: 3rem; height: 3rem; font-size: 1.25rem;">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <span class="small fw-bold text-uppercase text-secondary-muted">Today</span>
                </div>
                <h2 class="display-6 fw-bold mb-0 text-navy">@Model.TodayTransactions</h2>
                <p class="small mb-0 mt-2 text-secondary-muted fw-medium">New activities recorded</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Recent Activity Table -->
    <div class="col-xl-8 col-sm-12">
        <div class="card h-100">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-navy">Recent Financial Activity</h5>
                <a asp-controller="Transaction" asp-action="Index" class="btn btn-sm btn-secondary px-3">View All Logs</a>
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-bordered table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Description</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.RecentTransactions.Take(5))
                        {
                            <tr>
                                <td class="text-secondary-muted small">@t.Date.ToString("MMM dd")</td>
                                <td class="fw-medium">@t.Description</td>
                                <td class="text-end fw-bold text-navy">₱@t.Amount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Activity Charts -->
    <div class="col-xl-4 col-sm-12">
        <div class="card h-100">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-navy">Daily Trends</h5>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <label class="small text-uppercase fw-bold text-secondary-muted d-block mb-3">Volume Count</label>
                    <div style="height: 180px;">
                        <canvas id="transactionsCountChart"></canvas>
                    </div>
                </div>
                <div>
                    <label class="small text-uppercase fw-bold text-secondary-muted d-block mb-3">Revenue (₱)</label>
                    <div style="height: 180px;">
                        <canvas id="amountChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(JsonSerializer.Serialize(Model.ChartLabels));
        const countData = @Html.Raw(JsonSerializer.Serialize(Model.TransactionsPerDay));
        const amountData = @Html.Raw(JsonSerializer.Serialize(Model.AmountPerDay));

        const chartOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, ticks: { font: { size: 10 } } },
                y: { beginAtZero: true, ticks: { font: { size: 10 } } }
            }
        };

        new Chart(document.getElementById('transactionsCountChart'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    data: countData,
                    backgroundColor: '#5C5470',
                    borderRadius: 4
                }]
            },
            options: chartOptions
        });

        new Chart(document.getElementById('amountChart'), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    data: amountData,
                    borderColor: '#352F44',
                    borderWidth: 2,
                    tension: 0.4,
                    pointRadius: 0,
                    fill: true,
                    backgroundColor: 'rgba(53, 47, 68, 0.05)'
                }]
            },
            options: chartOptions
        });
    </script>
}
